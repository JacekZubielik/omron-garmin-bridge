{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Pin Python to 3.12 — garminconnect/pydantic incompatible with 3.13+",
      "matchPackageNames": ["python"],
      "matchManagers": ["dockerfile", "docker-compose", "pyenv", "github-actions"],
      "allowedVersions": ">=3.12.0 <3.13.0"
    }
  ]
}
